// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  image            String?
  emailVerified    DateTime?
  // C4 fix: passwordHash field for credentials auth
  passwordHash     String?
  role             UserRole  @default(USER)
  // H5 fix: unique constraint prevents duplicate Stripe customers
  stripeCustomerId String?   @unique

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// C2 fix: Subscription model synced from Stripe webhooks
// Admin list pages query this table instead of hitting Stripe directly
model Subscription {
  id                   String   @id @default(cuid())
  // Stripe subscription ID
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  userId               String?

  status               String   // active, canceled, trialing, past_due, etc.
  productId            String?  // Stripe product ID
  productName          String?
  priceId              String?
  planName             String?
  // Amount in cents
  amount               Int      @default(0)
  currency             String   @default("usd")
  interval             String?  // month, year
  intervalCount        Int?     @default(1)

  // Billing dates
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?

  // Metadata
  stripeMetadata       Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([userId])
  @@index([status])
  @@index([productId])
}

model Project {
  id               String   @id @default(cuid())
  name             String   @unique
  displayName      String
  description      String?
  stripeProductIds String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
