# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://platform.idioticventures.com
NEXTAUTH_SECRET=                        # openssl rand -base64 32

# ── Database (Vercel Postgres / Neon) ─────────────────────────────────────────
# These are auto-injected when you connect Vercel Postgres to this project.
# Prisma needs the pooled URL for queries and the direct URL for migrations.
POSTGRES_PRISMA_URL=                    # from Vercel Storage → your DB → .env.local tab
POSTGRES_URL_NON_POOLING=              # same tab — used as DIRECT_URL for migrations

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=matt@idioticventures.com   # comma-separated, never commit this
